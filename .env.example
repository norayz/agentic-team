# AWS Region for Bedrock (credentials mounted from ~/.aws)
AWS_REGION=eu-central-1

# E2B API key — get from e2b.dev
E2B_API_KEY=your_e2b_api_key_here

# GitHub personal access token — needs: repo scope
GITHUB_TOKEN=your_github_token_here

# Your GitHub repo in owner/repo format
GITHUB_REPO=norayz/agentic-team

# Webhook secret — any random string; must match what you set in GitHub repo webhook settings
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# Optional: override the model used by each agent (Bedrock model IDs)
# PM_MODEL=eu.anthropic.claude-opus-4-0-20250514
# TEAM_LEAD_MODEL=eu.anthropic.claude-opus-4-0-20250514
# ARCHITECT_MODEL=eu.anthropic.claude-sonnet-4-20250514
# BACKEND_MODEL=eu.anthropic.claude-haiku-4-5-20251001
# CODE_REVIEWER_MODEL=eu.anthropic.claude-sonnet-4-20250514
# QA_MODEL=eu.anthropic.claude-haiku-4-5-20251001
# DEVOPS_MODEL=eu.anthropic.claude-haiku-4-5-20251001
