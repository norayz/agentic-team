# Anthropic API key — get from console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# E2B API key — get from e2b.dev
E2B_API_KEY=your_e2b_api_key_here

# GitHub personal access token — needs: repo scope
GITHUB_TOKEN=your_github_token_here

# Your GitHub repo in owner/repo format (e.g. myorg/my-repo)
GITHUB_REPO=your_org/your_repo

# Webhook secret — any random string; must match what you set in GitHub repo webhook settings
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# Optional: override the model used by each agent (defaults shown)
# PM_MODEL=claude-opus-4-8
# TEAM_LEAD_MODEL=claude-opus-4-8
# ARCHITECT_MODEL=claude-sonnet-4-6
# BACKEND_MODEL=claude-haiku-4-5-20251001
# CODE_REVIEWER_MODEL=claude-sonnet-4-6
# QA_MODEL=claude-haiku-4-5-20251001
# DEVOPS_MODEL=claude-haiku-4-5-20251001
