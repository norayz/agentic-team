# Anthropic API key — get from console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# E2B API key — get from e2b.dev
E2B_API_KEY=your_e2b_api_key_here

# GitHub personal access token — needs: repo, issues, pull_requests scopes
GITHUB_TOKEN=your_github_token_here

# Your GitHub repo in owner/repo format
GITHUB_REPO=ylavi_tenb/agentic-team

# Webhook secret — set this in your GitHub repo webhook settings
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here
