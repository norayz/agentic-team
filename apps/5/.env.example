# Environment Configuration for Barista Site

# Node environment (development, production, test)
NODE_ENV=development

# Server port (default: 3000)
PORT=3000

# Host port for docker-compose (default: 3000)
HOST_PORT=3000

# SQLite database path
DATABASE_PATH=/app/data/barista.db

# (Optional) Application name/title
APP_NAME=Barista Site

# (Optional) Coffee house location/address
COFFEE_SHOP_NAME=My Coffee House
