# Barista Site - Environment Configuration
# Copy this file to .env and update values for your environment

# ============================================
# Application Settings
# ============================================

# Node environment: 'development' or 'production'
NODE_ENV=development

# Port the application listens on
PORT=3000

# ============================================
# Database Configuration
# ============================================

# Path to SQLite database file
# Development: ./data/barista.db (auto-created in volume)
# Production: /app/data/barista.db (on persistent volume)
DATABASE_PATH=./data/barista.db

# ============================================
# Deployment-Specific (Production)
# ============================================

# Only needed if deploying behind a reverse proxy (e.g., Nginx)
# Set to 'true' to trust X-Forwarded-* headers
TRUST_PROXY=false

# ============================================
# Optional: Features & Limits
# ============================================

# Maximum orders per day (informational; no enforced limit in v1)
MAX_ORDERS_PER_DAY=100