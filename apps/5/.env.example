# Barista Site Environment Variables

# Node Environment
NODE_ENV=development
# NODE_ENV=production  # Use for production deployments

# Server Port
PORT=3000

# Database Configuration
# SQLite database file path (relative to app working directory)
DB_PATH=./db/orders.db

# Logging
LOG_LEVEL=info
# LOG_LEVEL=debug   # Verbose logging for development
# LOG_LEVEL=warn    # Warnings and errors only
# LOG_LEVEL=error   # Errors only

# Feature Flags (optional)
# ENABLE_ORDER_EXPORT=false  # Future: export orders to CSV
