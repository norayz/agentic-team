# Barista Site Environment Variables
# Copy this file to .env and update values for your environment

# Node.js environment: development, production, or test
NODE_ENV=development

# Server port (default: 3000)
PORT=3000

# SQLite database file path
# In production, use an absolute path or a path outside the app directory for persistence
# In Docker, this should point to a volume mount
DATABASE_PATH=/app/db/orders.db

# Optional: Logging level (debug, info, warn, error)
LOG_LEVEL=info

# Optional: Menu data file path (default: ./data/menu.json)
MENU_DATA_PATH=./data/menu.json
