<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Menu - Barista Site</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header>
    <div class="container">
      <h1><a href="/">☕ Barista Site</a></h1>
      <nav>
        <a href="/">Menu</a>
        <a href="/cart" id="cart-link">Cart (<span id="cart-count">0</span>)</a>
      </nav>
    </div>
  </header>

  <main class="container">
    <h2>Our Menu</h2>
    <div class="menu-grid">
      <% menuItems.forEach(item => { %>
        <div class="menu-item">
          <h3><%= item.name %></h3>
          <p class="description"><%= item.description %></p>
          <p class="price">$<%= item.price.toFixed(2) %></p>
          <button 
            class="btn add-to-cart"
            data-id="<%= item.id %>"
            data-name="<%= item.name %>"
            data-price="<%= item.price %>">
            Add to Cart
          </button>
        </div>
      <% }); %>
    </div>
  </main>

  <footer>
    <div class="container">
      <p>&copy; 2024 Barista Site. All rights reserved.</p>
    </div>
  </footer>

  <script src="/js/cart.js"></script>
</body>
</html>
